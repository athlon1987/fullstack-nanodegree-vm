{
  "name": "future-founder-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive learning app that ingests, validates, sequences, and renders the Future Founder curriculum.",
  "scripts": {
    "dev": "vite",
    "build": "npm run validate && tsc -b && vite build",
    "preview": "vite preview",
    "validate": "tsx scripts/validate.ts",
    "gen:types": "json2ts curriculum.schema.json src/lib/curriculum.types.ts --additionalProperties false --style.singleQuote",
    "typecheck": "tsc -b --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.17.1",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
